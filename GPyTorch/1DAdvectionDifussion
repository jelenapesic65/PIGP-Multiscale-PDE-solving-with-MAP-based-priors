class GPRegressionModel(gpytorch.models.ExactGP):
    def __init__(self, train_x, train_y, likelihood):
        super(GPRegressionModel, self).__init__(train_x, train_y, likelihood)

        # SKI requires a grid size hyperparameter. This util can help with that. Here we are using a grid that has the same number of points as the training data (a ratio of 1.0). Performance can be sensitive to this parameter, so you may want to adjust it for your own problem on a validation set.
        grid_size = gpytorch.utils.grid.choose_grid_size(train_x,1.0)

        self.mean_module = gpytorch.means.ConstantMean()
        self.covar_module = gpytorch.kernels.ScaleKernel(
            gpytorch.kernels.GridInterpolationKernel(
                gpytorch.kernels.RBFKernel(), grid_size=grid_size, num_dims=1
            )
        )
        self.raw_kappa = torch.nn.Parameter(torch.tensor(0.6))
        self.raw_v = torch.nn.Parameter(torch.tensor(0.3))

    @property
    def kappa(self):
        return torch.nn.functional.softplus(self.raw_kappa)
    @property
    def v(self):
        return torch.nn.functional.softplus(self.raw_v)
        
    def forward(self, x):
        mean_x = self.mean_module(x)
        #covar_x = self.covar_module(x)
        Kuu = self.covar_module.base_kernel.base_kernel(u.unsqueeze(-1))
        W = build_W_total(a, b, c, x, u, float(h), self.kappa, self.v)
        covar_x = PDEInterpolatedLinearOperator(Kuu, W) 
        print('Covar shape:', covar_x.shape)
        print('Mean shape:', mean_x.shape)
        return gpytorch.distributions.MultivariateNormal(mean_x, covar_x)


